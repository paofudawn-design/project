# NPM 配置文件
# 取消注释并修改以下配置以使用代理

# HTTP 代理
# proxy=http://domain%5Cusername:pass%20word@192.168.40.21:8080

# HTTPS 代理
# https-proxy=http://domain%5Cusername:pass%20word@192.168.40.21:8080

# 注册表镜像（国内用户建议使用）
# registry=https://registry.npmmirror.com/

# 严格SSL
# strict-ssl=false

# 超时设置
# timeout=60000

# 重试次数
# fetch-retries=3